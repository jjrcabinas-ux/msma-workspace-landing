rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin: full access to everything.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email.lower() == 'jjrcabinas@gmail.com';
    }
    // Staff allowlist — keep in sync with ALLOWED_GOOGLE in index.html/app.html.
    // Admin-created email/password accounts must also be listed here.
    function isStaff() {
      return isAdmin() || (request.auth != null
        && request.auth.token.email.lower() in [
          'jjrcabinas@gmail.com'
        ]);
    }
    match /boards/{board} {
      allow read, write: if isStaff();
    }
    // Username -> email mapping. Single-doc reads are open so the login
    // form can resolve a username before authentication; listing is blocked.
    match /usernames/{username} {
      allow get: if true;
      allow list: if false;
      allow create: if isStaff() && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;
      allow update, delete: if isAdmin() || (isStaff() && resource.data.uid == request.auth.uid);
    }
    match /users/{uid} {
      allow read, write: if isAdmin() || (isStaff() && request.auth.uid == uid);
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
