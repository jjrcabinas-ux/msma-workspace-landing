rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin: full access to everything.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email.lower() == 'jjrcabinas@gmail.com';
    }
    // Staff = admin, or anyone whose email the admin added in the Members module.
    function isStaff() {
      return isAdmin() || (request.auth != null
        && exists(/databases/$(database)/documents/members/$(request.auth.token.email.lower())));
    }
    // Member registry, doc id = lowercase email. Admin manages it; a signed-in
    // user may only check their own membership (the registration gate).
    match /members/{email} {
      allow get: if isStaff() || (request.auth != null && request.auth.token.email.lower() == email);
      allow list: if isStaff();
      allow create, update, delete: if isAdmin();
    }
    // Legacy sheet doc (tasks array) — kept only so clients can migrate
    // their own data into the per-task docs below, then delete it.
    match /members/{email}/sheet/{doc} {
      allow read: if isStaff();
      allow write: if isAdmin() || (isStaff() && request.auth.token.email.lower() == email);
    }
    function isTaskOwner(email) {
      return isStaff() && request.auth.token.email.lower() == email;
    }
    // `due` must be a real timestamp (or null) so the overdue lock is
    // enforceable server-side, not just in the UI.
    function validTask() {
      return request.resource.data.get('due', null) == null
        || request.resource.data.due is timestamp;
    }
    // Overdue policy: 3+ days past due and still not Done — frozen for the
    // owner; only the admin (direct supervisor) may update or delete it.
    function lockedTask() {
      return resource.data.get('status', '') != 'Done'
        && resource.data.get('due', null) is timestamp
        && resource.data.due + duration.value(3, 'd') < request.time;
    }
    // Task Monitoring deliverables: one doc per task. Staff read the
    // cluster sheets. Once saved, a task's information is immutable for
    // the owner — only status and help may change (and not even those
    // once the overdue lock engages). Deletion and corrections are the
    // admin's (direct supervisor's) alone, so delete-and-recreate can't
    // dodge the immutability.
    // Senior Associates may create deliverables for members of their own
    // cluster (position comes from the profile; cluster from the registry).
    function isSeniorAssocOfSameCluster(email) {
      return isStaff()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('position', '') == 'Senior Associate'
        && get(/databases/$(database)/documents/members/$(request.auth.token.email.lower())).data.get('cluster', '') ==
           get(/databases/$(database)/documents/members/$(email)).data.get('cluster', 'none');
    }
    // Broadcast reminders shown in every member's notification bell.
    // Admin sends; staff read.
    match /announcements/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }
    // Work-from-home schedule: one doc per member holding their WFH dates.
    // Staff see everyone's; each member marks only their own days.
    match /members/{email}/wfh/{doc} {
      allow read: if isStaff();
      allow write: if isAdmin() || isTaskOwner(email);
    }
    match /members/{email}/tasks/{taskId} {
      allow read: if isStaff();
      allow create: if (isAdmin() || isTaskOwner(email) || isSeniorAssocOfSameCluster(email)) && validTask();
      allow update: if isAdmin() || (
        isTaskOwner(email)
        && !lockedTask()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'help'])
      );
      allow delete: if isAdmin();
    }
    // Personal boards: each member reads/writes only their own; admin sees all.
    match /users/{uid}/boards/{board} {
      allow read, write: if isAdmin() || (isStaff() && request.auth.uid == uid);
    }
    // Collection-group read so the Team dashboard view can query every
    // user's boards at once. Any staff member may look; writes stay
    // owner-or-admin via the match above.
    match /{path=**}/boards/{board} {
      allow read: if isStaff();
    }
    // Username -> email mapping. Single-doc reads are open so the login
    // form can resolve a username before authentication; listing is blocked.
    match /usernames/{username} {
      allow get: if true;
      allow list: if false;
      allow create: if isStaff() && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;
      allow update, delete: if isAdmin() || (isStaff() && resource.data.uid == request.auth.uid);
    }
    // Profiles are readable by all staff (the Team view shows owner names);
    // each user still only writes their own.
    match /users/{uid} {
      allow read: if isStaff();
      allow write: if isAdmin() || (isStaff() && request.auth.uid == uid);
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
